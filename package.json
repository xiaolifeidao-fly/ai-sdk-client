{
  "name": "ai-sdk-client",
  "version": "0.1.0",
  "private": true,
  "description": "HTTP relay for local Claude Code + Codex agentic SDKs",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.175",
    "@openai/codex-sdk": "^0.139.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "js-yaml": "^4.1.0",
    "p-queue": "^6.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
